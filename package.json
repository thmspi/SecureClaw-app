{
  "name": "secureclaw-app",
  "version": "1.0.0",
  "description": "SecureClaw - Desktop installer and manager for OpenClaw and NVIDIA NemoClaw",
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:renderer": "vite",
    "rebuild:native:deps": "electron-builder install-app-deps",
    "verify:native:electron": "node scripts/verify-native-electron.cjs",
    "rebuild:native": "npm run rebuild:native:deps && npm run verify:native:electron",
    "dev:desktop": "npm run rebuild:native && npm run build:main && VITE_DEV_SERVER_URL=http://localhost:3000 electron .",
    "dev:desktop:sim-install": "SECURECLAW_DEV_SIMULATE_INSTALL=1 npm run rebuild:native && SECURECLAW_DEV_SIMULATE_INSTALL=1 npm run build:main && SECURECLAW_DEV_SIMULATE_INSTALL=1 VITE_DEV_SERVER_URL=http://localhost:3000 electron .",
    "start": "npm run rebuild:native && npm run build:main && npm run build:renderer && electron .",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json && node scripts/write-dist-package-type.cjs",
    "build:renderer": "vite build",
    "test": "jest",
    "test:watch": "jest --watch",
    "type-check": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thmspi/SecureClaw-app.git"
  },
  "keywords": [
    "electron",
    "openclaw",
    "nemoclaw",
    "desktop-installer",
    "agent-ops"
  ],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/thmspi/SecureClaw-app/issues"
  },
  "homepage": "https://github.com/thmspi/SecureClaw-app#readme",
  "dependencies": {
    "@fontsource-variable/figtree": "^5.2.10",
    "@fontsource-variable/geist": "^5.2.8",
    "@monaco-editor/react": "4.7.0",
    "@rjsf/core": "6.4.2",
    "@rjsf/validator-ajv8": "6.4.2",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^41.1.1",
    "electron-log": "^5.4.3",
    "execa": "^9.6.1",
    "fast-redact": "^3.5.0",
    "framer-motion": "^12.38.0",
    "gray-matter": "4.0.3",
    "json5": "2.2.3",
    "lucide-react": "^1.7.0",
    "monaco-editor": "0.55.1",
    "monaco-yaml": "5.4.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shadcn": "^4.1.2",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "yaml": "2.8.3",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/archiver": "^7.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "tailwindcss": "^4.2.2",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "vite": "^6.4.1"
  }
}
